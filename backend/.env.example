# 智谱 AI API Key
# 推荐做法：设置为系统环境变量，不要在文件中写入明文
# ZHIPU_API_KEY=your-zhipu-api-key-here

# 模型配置（可选）
CHAT_MODEL=glm-4.5-air
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIMENSIONS=512
VISION_MODEL=glm-4.6v

# 数据库配置（可选，默认使用本地 MySQL）
DATABASE_URL=mysql+aiomysql://root:123456@localhost:3306/shuxiangge_bot

# MongoDB配置（可选，默认使用本地 MongoDB）
MONGODB_URL=mongodb://localhost:27017/shuxiangge_bot

# Redis配置（可选，默认使用本地 Redis）
REDIS_URL=redis://localhost:6379/0

# 调试模式（可选）
DEBUG=false

# RAG 轻量模式（可选）
# 当大模型网络不稳定、embedding 或 LLM 响应慢时，设置为 true 可关闭多查询扩展和 LLM 重排序，提升稳定性
# RAG_LITE=false

# JWT 配置（⚠️ 重要：生产环境必须修改为随机强密钥！）
# 建议使用命令生成：openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-change-in-production

# 生产模式静态文件配置（由 start.py --prod 自动设置，通常无需手动修改）
# SERVE_STATIC=false
# STATIC_DIR=../frontend/dist
# CORS_ORIGINS=*
# CORS_ALLOW_CREDENTIALS=false
